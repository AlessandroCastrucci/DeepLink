{
  "applinks": {
    "substitutionVariables": {
      "section": [
        "home",
        "download",
        "account",
        "settings"
      ],
      "rubric": [
        "series",
        "home",
        "movies"
      ]
    },
    "details": [
      {
        "appIDs": [
          "SLXSGJ3GVX.com.virgoplay.playvod.af"
        ],
        "components": [
          {
            "/": "/section/$(section)",
            "comment": "open specific section"
          },
          {
            "/": "/rubric/$(rubric)",
            "comment": "open detail specific rubric"
          },
          {
            "/": "/category/*",
            "comment": "open detail specific section"
          },
          {
            "?": {
              "authtoken": "*"
            },
            "comment": "push auto-login value"
          },
          {
            "?": {
              "snp_csid": "*"
            },
            "comment": "pass snowplow session"
          },
          {
            "/": "/debug",
            "?": {
              "authtoken": "*",
              "country": "??",
              "language": "??"
            },
            "comment": "force country and language only for debug"
          },
          {
            "/": "/forgotpassword",
            "?": {
              "authtoken": "*",
              "country": "??",
              "language": "??"
            },
            "comment": "force country and language only for debug"
          },
          {
            "/": "/",
            "exclude": true,
            "comment": "Exclude homepage"
          }
        ]
      }
    ]
  }
}
 